# Cloudflare Worker Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# Encryption key for user data (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=your-secure-random-key-here

# Email Service Configuration (Optional)
# Uncomment and configure if using email notifications

# SendGrid
# EMAIL_PROVIDER=sendgrid
# EMAIL_API_KEY=your-sendgrid-api-key
# EMAIL_FROM=noreply@yourdomain.com

# Mailgun
# EMAIL_PROVIDER=mailgun
# EMAIL_API_KEY=your-mailgun-api-key
# EMAIL_DOMAIN=mg.yourdomain.com
# EMAIL_FROM=noreply@yourdomain.com

# AWS SES
# EMAIL_PROVIDER=aws-ses
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1
# EMAIL_FROM=noreply@yourdomain.com

# Database Configuration (auto-generated by wrangler)
# D1_DATABASE_ID=your-database-id

# KV Namespace (optional)
# KV_NAMESPACE_ID=your-kv-namespace-id

# Application Settings
# APP_NAME=BLT Sizzle Check-in
# APP_URL=https://checkin.yourdomain.com

# Slack Configuration (Optional - can also be set per-user in UI)
# DEFAULT_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Timezone for scheduled tasks
# DEFAULT_TIMEZONE=UTC

# Debug mode (set to "true" for development)
# DEBUG=false
