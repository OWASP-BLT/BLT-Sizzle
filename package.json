{
  "name": "blt-sizzle-checkin",
  "version": "1.0.0",
  "description": "Daily check-in app for teams with Slack integration",
  "main": "src/index.py",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "db:create": "wrangler d1 create checkin-db",
    "db:init": "wrangler d1 execute checkin-db --file=./schema.sql",
    "db:query": "wrangler d1 execute checkin-db --command",
    "test": "python -m pytest tests/test_unit.py -v",
    "test:integration": "python -m pytest tests/test_api.py -v",
    "lint": "ruff check src/ tests/"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "python",
    "checkin",
    "slack",
    "team",
    "productivity"
  ],
  "author": "OWASP BLT",
  "license": "Apache-2.0",
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}
